# Gemini API Configuration
# Get your API key from: https://makersuite.google.com/app/apikey
GEMINI_API_KEY="Please set your Gemini API key here"

# Optional: Qdrant Configuration (defaults: localhost:6333)
QDRANT_HOST=localhost
QDRANT_PORT=6333
# Optional: Data storage location (default: data)
DATA_DIR=data
